<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Telas.ConfigUsuario">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ATAQUE AKUMA NO MI"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <TextView
            android:id="@+id/dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seus ataques de Akuma No Mi"
            android:gravity="center"
            android:textSize="25sp"
            android:layout_marginTop="30dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dialog_title"/>

        <Button
            android:id="@+id/ataque1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nome ataque"
            android:visibility="invisible"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/dialog_message"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <TextView
            android:id="@+id/descricao_ataque1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TextView"
            android:visibility="invisible"
            android:textSize="20dp"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/ataque1"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <Button
            android:id="@+id/ataque2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nome ataque"
            android:visibility="invisible"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/descricao_ataque1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <TextView
            android:id="@+id/descricao_ataque2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TextView"
            android:textSize="20dp"
            android:visibility="invisible"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/ataque2"
            app:layout_constraintLeft_toLeftOf="parent"/>
        <Button
            android:id="@+id/ataque3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nome ataque"
            android:layout_marginTop="20dp"
            android:visibility="invisible"
            app:layout_constraintTop_toBottomOf="@id/descricao_ataque2"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <TextView
            android:id="@+id/descricao_ataque3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TextView"
            android:textSize="20dp"
            android:visibility="invisible"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/ataque3"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <Button
            android:id="@+id/ataque4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nome ataque"
            android:visibility="invisible"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/descricao_ataque3"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <TextView
            android:id="@+id/descricao_ataque4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TextView"
            android:textSize="20dp"
            android:visibility="invisible"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/ataque4"
            app:layout_constraintLeft_toLeftOf="parent"/>
        <Button
            android:id="@+id/ataque5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nome ataque"
            android:visibility="invisible"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/descricao_ataque4"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <TextView
            android:id="@+id/descricao_ataque5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TextView"
            android:visibility="invisible"
            android:textSize="20dp"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/ataque5"
            app:layout_constraintLeft_toLeftOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>